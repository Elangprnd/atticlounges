{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth.js" },
    { "source": "/api/users/(.*)", "destination": "/api/auth.js" },
    { "source": "/api/debug/(.*)", "destination": "/api/auth.js" },
    
    { "source": "/api/products", "destination": "/api/products.js" },
    { "source": "/api/products/(.*)", "destination": "/api/products.js" },
    { "source": "/api/test", "destination": "/api/products.js" },
    
    { "source": "/api/cart/(.*)", "destination": "/api/orders.js" },
    { "source": "/api/orders", "destination": "/api/orders.js" },
    { "source": "/api/orders/(.*)", "destination": "/api/orders.js" },
    { "source": "/api/admin/orders", "destination": "/api/orders.js" },
    { "source": "/api/admin/orders/(.*)", "destination": "/api/orders.js" },
    { "source": "/api/admin/cleanup-orders", "destination": "/api/orders.js" },
    
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/models", "destination": "/api/chat.js" },

    { "source": "/admin-orders", "destination": "/pages/admin-orders.html" },
    { "source": "/admin", "destination": "/pages/admin.html" },
    { "source": "/cart", "destination": "/pages/cart.html" },
    { "source": "/chat", "destination": "/pages/chat.html" },
    { "source": "/detail", "destination": "/pages/detail.html" },
    { "source": "/orders", "destination": "/pages/orders.html" },
    { "source": "/payment", "destination": "/pages/payment.html" },
    { "source": "/product", "destination": "/pages/product.html" },
    { "source": "/profile", "destination": "/pages/profile.html" },
    { "source": "/wishlist", "destination": "/pages/wishlist.html" }
  ]
}